# Approval Gate — Silver Tier
# Copy to .env and adjust paths before running.

# Absolute path to the vault root (default: three levels up from this file)
VAULT_PATH=D:/AI_Employee_Vault

# Seconds between scans in --watch mode
POLL_INTERVAL=60

# Label written to Dashboard.md and vault logs
GATE_ACTOR=Approval Gate (Silver Tier)
