# ──────────────────────────────────────────────────────────────
#  Approval Request Generator — Gold Tier — Environment
#  Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────

# Absolute path to your Obsidian vault root
VAULT_PATH=D:/AI_Employee_Vault

# Seconds between passes in --watch mode
POLL_INTERVAL=60

# Payments above this dollar value trigger an approval request
PAYMENT_THRESHOLD=50.00

# Label written to logs and Dashboard.md as the requester
APPROVAL_ACTOR=Approval Generator (Gold Tier)

# Set to true to automatically move expired PENDING approval
# requests to /Rejected (default: false — just marks status)
AUTO_EXPIRE_MOVE=false
