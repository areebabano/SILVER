# ──────────────────────────────────────────────────────────────
#  File System Watcher — Environment Configuration
#  Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────

# Absolute path to your Obsidian vault root
VAULT_PATH=D:/AI_Employee_Vault

# Folder to monitor for new file drops (defaults to vault /Inbox)
DROP_FOLDER=/mnt/d/AI_Employee_Vault/Inbox

# Comma-separated list of file extensions to watch.
# Files with other extensions are silently ignored.
WATCH_EXTENSIONS=.pdf,.docx,.xlsx,.txt,.png,.jpg,.jpeg,.csv,.zip,.mp3,.mp4
