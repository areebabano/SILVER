# ──────────────────────────────────────────────────────────────
#  Gmail Watcher — Environment Configuration
#  Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────

# Your Gmail address
GMAIL_USER=areebabano986@gmail.com

# 16-character App Password (NOT your regular Gmail password).
# How to generate one:
#   1. Enable 2-Factor Authentication on your Google account.
#   2. Go to: Google Account → Security → 2-Step Verification → App passwords
#   3. Create a password for "Mail" and paste it below (spaces are fine).
GMAIL_APP_PASSWORD=your-gmail-app-password-here

# Absolute path to your Obsidian vault root
VAULT_PATH=D:/AI_Employee_Vault

# How often to check for new emails (seconds)
POLL_INTERVAL=60
