# ──────────────────────────────────────────────────────────────
#  LinkedIn Watcher — Environment Configuration
#  Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────

# Absolute path to your Obsidian vault root
VAULT_PATH=D:/AI_Employee_Vault

# How often to scan messages + notifications (seconds)
POLL_INTERVAL=60

# Where Chromium stores the LinkedIn session.
# After you log in once, this profile keeps you authenticated.
PLAYWRIGHT_PROFILE_PATH=/mnt/d/AI_Employee_Vault/.li_watcher_playwright

# Set to true to hide the browser window after first login
HEADLESS=false

# How long to wait for manual login on first run (seconds)
LOGIN_TIMEOUT_SECONDS=120

# Comma-separated keywords that indicate a business enquiry.
# Case-insensitive. Add your own service names here.
SERVICE_KEYWORDS=consulting,services,hire,project,proposal,quote,retainer,contract,partnership,collaboration,work together,offer,pricing,rates,available,freelance,agency,solution
