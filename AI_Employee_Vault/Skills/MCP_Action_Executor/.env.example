# ──────────────────────────────────────────────────────────────
#  MCP Action Executor — Gold Tier — Environment Configuration
#  Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────

# Absolute path to your Obsidian vault root
VAULT_PATH=D:/AI_Employee_Vault

# How often to poll /Approved in --watch mode (seconds)
POLL_INTERVAL=30

# ── Safety ─────────────────────────────────────────────────────
# Set to true to log all intended actions WITHOUT sending anything
# or moving any files.  Use this to verify behaviour before going live.
DRY_RUN=true

# Label written to logs and Dashboard.md as the action author
EXECUTOR_ACTOR=AI Employee (Gold Tier)

# ── Gmail MCP (SMTP gateway) ───────────────────────────────────
# Your Gmail address (must match the account the App Password was created for)
GMAIL_USER=areebabano986@gmail.com

# 16-character App Password (NOT your regular password).
# Generate: Google Account → Security → 2-Step Verification → App passwords
GMAIL_APP_PASSWORD=your-gmail-app-password-here

# Display name used in the From: header of sent emails
GMAIL_FROM_NAME=Areeba Bano

# ── WhatsApp MCP (Playwright gateway) ─────────────────────────
# Chromium profile that holds the WhatsApp Web session.
# Should match PLAYWRIGHT_PROFILE_PATH in WhatsApp_Watcher/.env
# (so the QR code is only ever scanned once).
WA_PLAYWRIGHT_PROFILE_PATH=/mnt/d/AI_Employee_Vault/.wa_watcher_playwright

# ── LinkedIn MCP (Playwright gateway) ─────────────────────────
# Chromium profile that holds the LinkedIn session.
# Should match PLAYWRIGHT_PROFILE_PATH in LinkedIn_Watcher/.env
LI_PLAYWRIGHT_PROFILE_PATH=/mnt/d/AI_Employee_Vault/.li_watcher_playwright

# Set to true to hide browser windows during WhatsApp / LinkedIn dispatch
HEADLESS=false
