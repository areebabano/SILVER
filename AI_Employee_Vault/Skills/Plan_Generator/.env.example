# ──────────────────────────────────────────────────────────────
#  Plan Generator — Silver Tier — Environment Configuration
#  Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────

# Absolute path to your Obsidian vault root
VAULT_PATH=D:/AI_Employee_Vault

# Seconds between polls when running in --watch mode
POLL_INTERVAL=120

# ── Silver Tier: Claude API ────────────────────────────────────
# Obtain your key at: https://console.anthropic.com/
# If left blank the script uses the rule-based fallback engine.
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Claude model to use for plan generation.
# Recommended: claude-haiku-4-5-20251001 (fast + economical)
# Upgrade to:  claude-sonnet-4-6 for higher-quality plans.
CLAUDE_MODEL=claude-haiku-4-5-20251001
