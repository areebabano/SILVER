# ──────────────────────────────────────────────────────────────
#  WhatsApp Watcher — Environment Configuration
#  Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────

# Absolute path to your Obsidian vault root
VAULT_PATH=D:/AI_Employee_Vault

# Comma-separated keywords to watch for (case-insensitive)
KEYWORDS=urgent,asap,invoice,payment,help

# How often to scan the chat list (seconds)
POLL_INTERVAL=30

# Where Chrome stores the WhatsApp Web session.
# After you scan the QR code once, this profile keeps you logged in.
# Leave blank to use the default: ~/.wa_watcher_profile
CHROME_PROFILE_PATH=/mnt/d/AI_Employee_Vault/.chrome_wa_profile
